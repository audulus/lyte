{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Lyte",
    "scopeName": "source.lyte",
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#numbers" },
        { "include": "#lambdas" },
        { "include": "#function-calls" },
        { "include": "#function-decls" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [{
                "name": "comment.line.double-slash.lyte",
                "match": "//.*$"
            }]
        },
        "keywords": {
            "patterns": [{
                "name": "keyword.control.lyte",
                "match": "\\b(if|else|while|for|var|let|where|assert)\\b"
            }, {
                "name": "keyword.declaration.lyte",
                "match": "\\b(struct|enum|interface)\\b"
            }]
        },
        "types": {
            "patterns": [{
                "name": "storage.type.lyte",
                "match": "\\b(i8|u8|i32|u32|f32|f64)\\b"
            }]
        },
        "numbers": {
            "patterns": [{
                "name": "constant.numeric.float.lyte",
                "match": "\\b[0-9]+\\.[0-9]+\\b"
            }, {
                "name": "constant.numeric.integer.lyte",
                "match": "\\b[0-9]+\\b"
            }]
        },
        "lambdas": {
            "patterns": [{
                "name": "keyword.operator.lambda.lyte",
                "match": "\\|"
            }]
        },
        "function-calls": {
            "patterns": [{
                "name": "entity.name.function.lyte",
                "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
            }]
        },
        "function-decls": {
            "patterns": [{
                "comment": "top-level function declaration: name followed by < or ( at start of expression context",
                "name": "entity.name.function.lyte",
                "match": "^([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*[<({])"
            }]
        },
        "operators": {
            "patterns": [{
                "name": "keyword.operator.arrow.lyte",
                "match": "->|→"
            }, {
                "name": "keyword.operator.comparison.lyte",
                "match": "==|!=|<=|>="
            }, {
                "name": "keyword.operator.assignment.lyte",
                "match": "(?<![=!<>])=(?!=)"
            }, {
                "name": "keyword.operator.arithmetic.lyte",
                "match": "[+\\-*/]"
            }, {
                "name": "keyword.operator.comparison.lyte",
                "match": "[<>]"
            }]
        }
    }
}
