{
    "name": "lyte-language",
    "displayName": "Lyte",
    "description": "Language support for the Lyte programming language",
    "version": "0.2.0",
    "engines": { "vscode": "^1.75.0" },
    "categories": ["Programming Languages"],
    "activationEvents": ["onLanguage:lyte"],
    "main": "./extension.js",
    "contributes": {
        "languages": [{
            "id": "lyte",
            "aliases": ["Lyte", "lyte"],
            "extensions": [".lyte"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "lyte",
            "scopeName": "source.lyte",
            "path": "./syntaxes/lyte.tmLanguage.json"
        }],
        "configuration": {
            "type": "object",
            "title": "Lyte",
            "properties": {
                "lyte.lspPath": {
                    "type": "string",
                    "default": "lyte-lsp",
                    "description": "Path to the lyte-lsp binary"
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    }
}
