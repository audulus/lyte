// Sort benchmark — bytecode golden test.
// Tracks codegen quality for the quicksort hot loop.

lcg(state: i32) -> i32 {
    (state * 1103 + 12345) % 1000000
}

main {
    var n = 10000
    var iters = 50
    var a: [i32; 10000]

    var checksum = 0

    for iter in 0 .. iters {
        var seed = iter * 7 + 42
        for i in 0 .. n {
            seed = lcg(seed)
            a[i] = seed
        }

        sort(a)

        if n > 1 {
            checksum = checksum + a[0] + a[n - 1]
        }
    }
}

