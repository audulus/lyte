//     22: SliceLoad32 { dst: 3, slice: 5, index: 1 }
//     23: SliceStore32 { slice: 5, index: 9, src: 3 }
//     24: SliceStore32 { slice: 5, index: 1, src: 2 }
//     25: SliceLoad32 { dst: 2, slice: 6, index: 9 }
//     26: SliceLoad32 { dst: 3, slice: 6, index: 1 }
//     27: SliceStore32 { slice: 6, index: 9, src: 3 }
//     28: SliceStore32 { slice: 6, index: 1, src: 2 }
// =>  29: IAddImm { dst: 9, src: 9, imm: 1 }
//     30: Jump { offset: -24 }
// =>  31: LoadImm { dst: 1, value: 0 }
//     32: Move { dst: 0, src: 1 }
//     33: RestoreRegs { start_reg: 1, count: 10, slot: 8 }
//     34: Return
// fn bit_reverse (params: 2, locals: 64 bytes):
//      0: SaveRegs { start_reg: 0, count: 8, slot: 0 }
//      1: Move { dst: 2, src: 1 }
//      2: LoadImm { dst: 1, value: 0 }
//      3: Move { dst: 3, src: 0 }
//      4: LoadImm { dst: 4, value: 0 }
// =>   5: ILtJump { a: 4, b: 2, offset: 9 }
//      6: LoadImm { dst: 5, value: 2 }
//      7: IMul { dst: 6, a: 1, b: 5 }
//      8: LoadImm { dst: 5, value: 2 }
//      9: IRem { dst: 7, a: 3, b: 5 }
//     10: IAdd { dst: 1, a: 6, b: 7 }
//     11: LoadImm { dst: 5, value: 2 }
//     12: IDiv { dst: 3, a: 3, b: 5 }
//     13: IAddImm { dst: 4, src: 4, imm: 1 }
//     14: Jump { offset: -10 }
// =>  15: Move { dst: 0, src: 1 }
//     16: RestoreRegs { start_reg: 1, count: 7, slot: 8 }
//     17: Return
// locals:
//   r2	bits
//   r2	x

bit_reverse(x: i32, bits: i32) -> i32 {
    var result = 0
    var val = x
    for i in 0 .. bits {
        result = result * 2 + val % 2
        val = val / 2
    }
    result
}

bit_reverse_permute(re: [f32], im: [f32]) {
    for i in 0 .. re.len {
        var j = bit_reverse(i, 10)
        if i < j && j < re.len && i < im.len && j < im.len {
            var tr = re[i]
            re[i] = re[j]
            re[j] = tr
            var ti = im[i]
            im[i] = im[j]
            im[j] = ti
        }
    }
}

fft(re: [f32], im: [f32]) {
    var n = re.len
    var pi = 3.14159265

    bit_reverse_permute(re, im)

    var size = 2
    while size <= n {
        var half = size / 2
        var angle = 0.0 - 2.0 * pi / (size as f32)

        var group = 0
        while group < n {
            for k in 0 .. half {
                var theta = angle * (k as f32)
                var wr = cos(theta)
                var wi = sin(theta)

                var i = group + k
                var j = i + half

                if j < re.len && j < im.len {
                    var tr = wr * re[j] - wi * im[j]
                    var ti = wr * im[j] + wi * re[j]

                    re[j] = re[i] - tr
                    im[j] = im[i] - ti
                    re[i] = re[i] + tr
                    im[i] = im[i] + ti
                }
            }
            group = group + size
        }
        size = size * 2
    }
}

main {
    var n = 1024
    var iters = 2000
    var re: [f32; 1024]
    var im: [f32; 1024]

    var checksum = 0.0

    for iter in 0 .. iters {
        var freq1 = 50.0
        var freq2 = 120.0
        for i in 0 .. n {
            var t = (i as f32) / (n as f32)
            re[i] = sin(2.0 * 3.14159265 * freq1 * t) + 0.5 * sin(2.0 * 3.14159265 * freq2 * t)
            im[i] = 0.0
        }

        fft(re, im)

        checksum = checksum + re[0]
    }
}
