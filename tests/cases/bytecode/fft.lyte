// locals:
//   slot 0	re
//   slot 2	im
// fn bit_reverse_permute (params: 2, locals: 120 bytes):
//      0: SaveRegs { start_reg: 0, count: 11, slot: 32 }
//      1: LocalAddr { dst: 5, slot: 0 }  ; re
//      2: MemCopy { dst: 5, src: 0, size: 12 }
//      3: LocalAddr { dst: 6, slot: 2 }  ; im
//      4: MemCopy { dst: 6, src: 1, size: 12 }
//      5: Load32Off { dst: 7, base: 5, offset: 8 }
//      6: Load32Off { dst: 8, base: 6, offset: 8 }
