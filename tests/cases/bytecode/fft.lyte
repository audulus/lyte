//     16: ILt { dst: 2, a: 9, b: 8 }
//     17: And { dst: 3, a: 4, b: 2 }
//     18: ILt { dst: 2, a: 0, b: 8 }
//     19: And { dst: 4, a: 3, b: 2 }
