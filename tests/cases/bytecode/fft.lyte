//      1: Move { dst: 5, src: 0 }
//      2: Move { dst: 6, src: 1 }
//      3: Load32Off { dst: 7, base: 0, offset: 8 }
//      4: Load32Off { dst: 8, base: 1, offset: 8 }
//      5: LoadImm { dst: 9, value: 0 }
//      6: Load32Off { dst: 10, base: 0, offset: 8 }
// =>   7: ILtJump { a: 9, b: 10, offset: 23 }
//      8: LoadImm { dst: 1, value: 10 }
//      9: Move { dst: 2, src: 9 }
//     10: Move { dst: 3, src: 1 }
//     11: Call { func: 3, args_start: 2, arg_count: 2 }
//     12: Move { dst: 1, src: 0 }
