//     10: LoadImm { dst: 1, value: 10 }
//     11: Move { dst: 2, src: 9 }
//     12: Move { dst: 3, src: 1 }
//     13: Call { func: 3, args_start: 2, arg_count: 2 }
//     14: Move { dst: 1, src: 0 }
//     15: ILt { dst: 2, a: 9, b: 0 }
//     16: ILt { dst: 3, a: 0, b: 7 }
//     17: And { dst: 4, a: 2, b: 3 }
//     18: ILt { dst: 2, a: 9, b: 8 }
//     19: And { dst: 3, a: 4, b: 2 }
//     20: ILt { dst: 2, a: 0, b: 8 }
//     21: And { dst: 4, a: 3, b: 2 }
//     22: JumpIfZero { cond: 4, offset: 10 }
//     23: LocalAddr { dst: 5, slot: 0 }  ; re
//     24: SliceLoad32 { dst: 2, slice: 5, index: 9 }
//     25: SliceLoad32 { dst: 3, slice: 5, index: 1 }
//     26: SliceStore32 { slice: 5, index: 9, src: 3 }
//     27: SliceStore32 { slice: 5, index: 1, src: 2 }
//     28: LocalAddr { dst: 6, slot: 2 }  ; im
//     29: SliceLoad32 { dst: 2, slice: 6, index: 9 }
//     30: SliceLoad32 { dst: 3, slice: 6, index: 1 }
//     31: SliceStore32 { slice: 6, index: 9, src: 3 }
//     32: SliceStore32 { slice: 6, index: 1, src: 2 }
// =>  33: IAddImm { dst: 9, src: 9, imm: 1 }
//     34: Jump { offset: -26 }
// =>  35: LoadImm { dst: 1, value: 0 }
//     36: Move { dst: 0, src: 1 }
//     37: RestoreRegs { start_reg: 1, count: 10, slot: 40 }
//     38: Return
// locals:
//   slot 0	re
//   slot 2	im
// fn bit_reverse (params: 2, locals: 64 bytes):
//      0: SaveRegs { start_reg: 0, count: 8, slot: 0 }
//      1: Move { dst: 2, src: 1 }
//      2: LoadImm { dst: 1, value: 0 }
//      3: Move { dst: 3, src: 0 }
//      4: LoadImm { dst: 4, value: 0 }
// =>   5: ILtJump { a: 4, b: 2, offset: 9 }
//      6: LoadImm { dst: 5, value: 2 }
//      7: IMul { dst: 6, a: 1, b: 5 }
//      8: LoadImm { dst: 5, value: 2 }
//      9: IRem { dst: 7, a: 3, b: 5 }
//     10: IAdd { dst: 1, a: 6, b: 7 }
//     11: LoadImm { dst: 5, value: 2 }
//     12: IDiv { dst: 3, a: 3, b: 5 }
//     13: IAddImm { dst: 4, src: 4, imm: 1 }
//     14: Jump { offset: -10 }
// =>  15: Move { dst: 0, src: 1 }
//     16: RestoreRegs { start_reg: 1, count: 7, slot: 8 }
//     17: Return
// locals:
//   r2	bits
//   r2	x

bit_reverse(x: i32, bits: i32) -> i32 {
    var result = 0
    var val = x
    for i in 0 .. bits {
        result = result * 2 + val % 2
        val = val / 2
    }
    result
}

bit_reverse_permute(re: [f32], im: [f32]) {
    for i in 0 .. re.len {
        var j = bit_reverse(i, 10)
        if i < j && j < re.len && i < im.len && j < im.len {
            var tr = re[i]
            re[i] = re[j]
            re[j] = tr
            var ti = im[i]
            im[i] = im[j]
            im[j] = ti
        }
    }
}

fft(re: [f32], im: [f32]) {
    var n = re.len
    var pi = 3.14159265

    bit_reverse_permute(re, im)

    var size = 2
    while size <= n {
        var half = size / 2
        var angle = 0.0 - 2.0 * pi / (size as f32)

        var group = 0
        while group < n {
            for k in 0 .. half {
                var theta = angle * (k as f32)
                var wr = cos(theta)
                var wi = sin(theta)

                var i = group + k
                var j = i + half

                if j < re.len && j < im.len {
                    var tr = wr * re[j] - wi * im[j]
                    var ti = wr * im[j] + wi * re[j]

                    re[j] = re[i] - tr
                    im[j] = im[i] - ti
                    re[i] = re[i] + tr
                    im[i] = im[i] + ti
                }
            }
            group = group + size
        }
        size = size * 2
    }
}

main {
    var n = 1024
    var iters = 2000
    var re: [f32; 1024]
    var im: [f32; 1024]

    var checksum = 0.0

    for iter in 0 .. iters {
        var freq1 = 50.0
        var freq2 = 120.0
        for i in 0 .. n {
            var t = (i as f32) / (n as f32)
            re[i] = sin(2.0 * 3.14159265 * freq1 * t) + 0.5 * sin(2.0 * 3.14159265 * freq2 * t)
            im[i] = 0.0
        }

        fft(re, im)

        checksum = checksum + re[0]
    }
}
