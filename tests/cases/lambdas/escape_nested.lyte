// args: -c
// expected stdout:
// ❌ ../tests/cases/lambdas/escape_nested.lyte:11:16: closure with captured variables cannot be returned (captured addresses would dangle after the frame exits)
//             return f
//                    ^

make(x: i32, flag: i32) → i32 → i32 {
    var f = (|y| x + y)
    var g = (|y| y * 2)
    if flag > 0 {
        return f
    } else {
        return g
    }
}
