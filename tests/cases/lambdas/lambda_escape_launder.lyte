// expected stdout:
// ❌ ../tests/cases/lambdas/lambda_escape_launder.lyte:13:12: closure with captured variables cannot be returned (captured addresses would dangle after the frame exits)
//         return launder(f)
//                ^

launder(f: void → i32) → void → i32 {
    return f
}

get_fn() → void → i32 {
    var x = 0
    var f = (| | x)
    return launder(f)
}
