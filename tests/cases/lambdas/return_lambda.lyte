// expected stdout:
// compilation successful
// assert(true)
// assert(true)

// Non-capturing lambda can be returned
make_doubler() -> i32 -> i32 {
    return (|x| x * 2)
}

make_adder_fixed() -> i32 -> i32 {
    return (|x| x + 10)
}

main {
    var d = make_doubler()
    assert(d(5) == 10)

    var a = make_adder_fixed()
    assert(a(7) == 17)
}
