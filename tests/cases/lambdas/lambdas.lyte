add_one(x: i32) → i32 { return x + 1 }

test_lambda_basic {
    var f = |x| x+1
    assert(f(1) == 2)
}

test_lambda_call {
    var x = (|x| x+1)(1)
    assert(x == 2)
}

test_lambda_nested {
    var f = |x| {
        (|x| x+1)(x)
    }
    assert(f(1) == 2)
}

call_test(f: i32 → i32) {
    assert(f(1) == 2)
}

test_lambda_arg {
    call_test( |x| x+1 )
}

test_lambda_infer {
    var f = |x| x+1
    assert(f(1) == 2)
}

test_lambda_infer2 {
    var f = |x| x
    assert(f(1) == 1)
}

main {
    test_lambda_basic()
    test_lambda_call()
    test_lambda_nested()
    test_lambda_arg()
    test_lambda_infer()
    test_lambda_infer2()
}
