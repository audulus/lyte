// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// vm execution successful

enum Direction { Up, Down, Left, Right }

is_vertical(d: Direction) -> bool {
    (d == .Up) || (d == .Down)
}

main {
    assert(is_vertical(.Up))
    assert(!is_vertical(.Left))
}
