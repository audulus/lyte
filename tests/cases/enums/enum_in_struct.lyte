// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// assert(true)
// executing VM code
// assert(true)
// assert(true)
// vm execution successful

enum Status { Active, Inactive }

struct Item {
    value: i32,
    status: Status
}

main {
    var item: Item
    item.value = 42
    item.status = .Active
    assert(item.status == .Active)
    assert(item.value == 42)
}
