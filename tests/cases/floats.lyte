main {
    assert(1.0 == 1.0)
    assert(1.0 < 2.0)
    assert(2.0 > 1.0)
    assert(1.0 != 2.0)
    assert(1.0 <= 1.0)
    assert(1.0 >= 1.0)
    assert(1.0 + 1.0 == 2.0)
    assert(1.0 + 1.0 == 1.0 + 1.0)
}
