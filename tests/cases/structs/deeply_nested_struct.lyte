// args: -c
// expected stdout:
// compilation successful
// assert(true)

struct Inner {
    value: i32
}

struct Middle {
    inner: Inner
}

struct Outer {
    middle: Middle
}

struct Top {
    outer: Outer
}

main {
    var t: Top
    t.outer.middle.inner.value = 42
    assert(t.outer.middle.inner.value == 42)
}
