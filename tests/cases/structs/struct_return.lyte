// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// executing VM code
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// vm execution successful

struct Point {
    x: i32,
    y: i32
}

make_point(x: i32, y: i32) → Point {
    var p: Point
    p.x = x
    p.y = y
    return p
}

translate(p: Point, dx: i32, dy: i32) → Point {
    var q: Point
    q.x = p.x + dx
    q.y = p.y + dy
    return q
}

main {
    var p = make_point(1, 2)
    assert(p.x == 1)
    assert(p.y == 2)

    var q = translate(p, 3, 4)
    assert(q.x == 4)
    assert(q.y == 6)
}
