// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// assert(true)
// executing VM code
// assert(true)
// assert(true)
// vm execution successful

struct Buffer {
    data: [i32; 512],
    len: i32
}

main {
    var buf: Buffer
    buf.len = 512
    for i in 0 .. 512 {
        buf.data[i] = i
    }
    assert(buf.data[511] == 511)
    assert(buf.len == 512)
}
