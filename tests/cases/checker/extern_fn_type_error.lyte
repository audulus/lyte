// Test: extern function type errors are caught.
// args: --check
// expected stdout:
// ❌ ../tests/cases/checker/extern_fn_type_error.lyte:11:18: argument types don't match function: (i32, i32) → i32 vs (f32, i32) → i32
//         var result = host_add(1.0, 2)
//                      ^

extern fn host_add(a: i32, b: i32) -> i32

fn main() {
    var result = host_add(1.0, 2)
}
