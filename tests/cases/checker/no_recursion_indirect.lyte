// args: --check --no-recursion
// expected stdout:
// ❌ ../tests/cases/checker/no_recursion_indirect.lyte:22:27: --no-recursion: lambda in `main` is recursive
//         g = (|n: i32| g(n - 1))
//                               ^
//
// `apply(f, x)` does an indirect call through a parameter and
// `call_it(|n| n+y, ...)` passes a lambda with a non-fn capture: both
// are benign under the edge-modelled rule. The only true recursion is
// the lambda that reassigns `g` to call itself through the captured
// fn-typed var — that forms a self-loop in the call graph.
apply(f: i32 -> i32, n: i32) -> i32 {
    return f(n - 1) + 1
}

good(n: i32) -> i32 {
    return n + 1
}

main {
    var g = |n: i32| 0
    g = (|n: i32| g(n - 1))
    print(apply(good, 3))
}
