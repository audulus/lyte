// args: -c
// expected stdout:
// compilation successful
// assert(true)
// assert(true)

// A macro will be substituted into the call site
// instead of called.
macro swap(x, y) {
    let tmp = x
    x = y
    y = tmp
}

main {
    var a = 1
    var b = 2
    @swap(a, b)
    assert(a == 2)
    assert(b == 1)
}
