// expected stdout:
// compilation successful
// assert(true)
// assert(true)

const H = 2
const W = 3

set_row(buf: [f32], idx: i32, value: f32) {
    if idx >= 0 && idx < buf.len {
        buf[idx] = value
    }
}

get_row(buf: [f32], idx: i32) -> f32 {
    var value = 0.0
    if idx >= 0 && idx < buf.len {
        value = buf[idx]
    }
    value
}

main {
    var table: [[f32; W]; H]

    set_row(table[0], 1, 3.0)
    set_row(table[1], 2, 7.0)

    assert(get_row(table[0], 1) == 3.0)
    assert(get_row(table[1], 2) == 7.0)
}
