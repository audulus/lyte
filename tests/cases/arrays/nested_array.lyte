// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// executing LLVM code
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// executing VM code
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// vm execution successful

main {
    var a: [[i8;4]; 4]
    a[0][0] = 'x'
    assert(a[0][0] == 'x')

    var b = a
    b[0][0] = 'y'
    b[0][1] = 'z'

    assert(b[0][0] == 'y')
    assert(b[0][1] == 'z')

    assert(a[0][0] == 'x')
}
