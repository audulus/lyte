// compilation successful
// assert(true)
// assert(true)
// assert(true)

map<T0, T1, N>(a: [T0; N], f: T0 → T1) → [T1; N] {
   var i = 0
   var b: [T1; N]
   while i < a.len {
       b[i] = f(a[i])
       i = i + 1
   }
   b
}

add_one(x: i32) → i32 { x + 1 }

test_map {
    let a = map([1,2,3], add_one)
    assert(a == [2,3,4])

    let b = map([1,2,3], |x| x+2)
    assert(b == [3,4,5])
    
    let f = |x| x+3
    let c = map([1,2,3], f)
    assert(c == [4,5,6])
}

main {
    test_map()
}
