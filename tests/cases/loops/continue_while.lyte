// expected stdout:
// compilation successful
// assert(true)
// assert(true)

main {
    // Skip even numbers with continue
    var sum = 0
    var i = 0
    while i < 10 {
        i = i + 1
        if i % 2 == 0 {
            continue
        }
        sum = sum + i
    }
    // 1+3+5+7+9 = 25
    assert(sum == 25)

    // Continue with nested loops
    var total = 0
    var j = 0
    while j < 5 {
        j = j + 1
        if j == 3 {
            continue
        }
        total = total + j
    }
    // 1+2+4+5 = 12
    assert(total == 12)
}
