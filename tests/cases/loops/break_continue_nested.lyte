// expected stdout:
// compilation successful
// assert(true)
// assert(true)

main {
    // Break only affects innermost loop
    var outer_count = 0
    for i in 0 .. 5 {
        outer_count = outer_count + 1
        for j in 0 .. 100 {
            if j == 2 {
                break
            }
        }
    }
    assert(outer_count == 5)

    // Continue only affects innermost loop
    var sum = 0
    for i in 0 .. 3 {
        for j in 0 .. 5 {
            if j % 2 == 0 {
                continue
            }
            sum = sum + 1
        }
    }
    // 3 outer * 2 odd inner (1,3) = 6
    assert(sum == 6)
}
