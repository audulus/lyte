// Bytecode-level check for empty string handling (no execution).
// args: --bytecode
// expected stdout:
// fn main (params: 0, locals: 64 bytes):
//      0: SaveRegs { start_reg: 0, count: 5, slot: 24 }
//      1: LocalAddr { dst: 1, slot: 0 }
//      2: LocalAddr { dst: 2, slot: 1 }
//      3: LoadImm { dst: 3, value: 0 }
//      4: Store8Off { base: 2, offset: 0, src: 3 }
//      5: MemCopy { dst: 1, src: 2, size: 1 }
//      6: LoadImm { dst: 2, value: 0 }
//      7: LoadImm { dst: 3, value: 1 }
//      8: IMul { dst: 4, a: 2, b: 3 }
//      9: IAdd { dst: 2, a: 1, b: 4 }
//     10: Load8 { dst: 3, addr: 2 }
//     11: LoadImm { dst: 2, value: 0 }
//     12: I32ToI8 { dst: 4, src: 2 }
//     13: IEq { dst: 2, a: 3, b: 4 }
//     14: Assert { src: 2 }
//     15: LocalAddr { dst: 2, slot: 2 }
//     16: LoadImm { dst: 3, value: 0 }
//     17: Store8Off { base: 2, offset: 0, src: 3 }
//     18: MemEq { dst: 3, a: 1, b: 2, size: 1 }
//     19: Assert { src: 3 }
//     20: LoadImm { dst: 1, value: 0 }
//     21: Move { dst: 0, src: 1 }
//     22: RestoreRegs { start_reg: 1, count: 4, slot: 32 }
//     23: Return

main {
    var s = ""
    assert(s[0] == 0 as i8)
    assert(s == "")
}
