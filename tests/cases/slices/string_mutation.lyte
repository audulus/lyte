main {
    // mutate individual characters
    var s = "abcd"
    s[0] = 'z'
    s[3] = 'w'
    assert(s[0] == 'z')
    assert(s[1] == 'b')
    assert(s[2] == 'c')
    assert(s[3] == 'w')
}
