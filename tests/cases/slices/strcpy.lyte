// args: -t
// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// vm execution successful

main {
    var dst = "     "
    var src = "hello"
    strcpy(dst, src)
    assert(dst[0] == 'h')
    assert(dst[4] == 'o')

    // shorter src: copied values and zero-filled remainder
    var dst2 = "xxxx"
    var src2 = "AB"
    strcpy(dst2, src2)
    assert(dst2[0] == 'A')
    assert(dst2[1] == 'B')
    assert(dst2[2] == 0 as i8)
    assert(dst2[3] == 0 as i8)
}
