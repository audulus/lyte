// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)

main {
    // empty string
    assert(strlen("") == 0)

    // single char
    assert(strlen("a") == 1)

    // multi char
    assert(strlen("hello") == 5)

    // zero-initialized array should have strlen 0
    var buf: [i8; 8]
    assert(strlen(buf) == 0)
}
