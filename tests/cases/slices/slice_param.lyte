// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// executing LLVM code
// compilation successful
// assert(true)
// executing VM code
// assert(true)
// vm execution successful

sum(a: [i32]) -> i32 {
    var s = 0
    for i in 0 .. a.len {
        s = s + a[i]
    }
    s
}

main {
    assert(sum([1, 2, 3]) == 6)
}
