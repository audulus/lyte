// expected stdout:
// compilation successful
// 6
// 12

sum(a: [i32]) -> i32 {
    var s = 0
    for i in 0 .. a.len { s = s + a[i] }
    s
}

sum(a: [f32]) -> f32 {
    var s = 0.0
    for i in 0 .. a.len { s = s + a[i] }
    s
}

main {
    print(sum([1, 2, 3]))
    print(sum([1.0, 2.0, 3.0, 6.0]) as i32)
}
