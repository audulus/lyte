// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

second(a: [f32]) -> f32 {
    if 1 < a.len {
        a[0 + 1]
    } else {
        0.0
    }
}

bump_second(a: [f32]) {
    if 1 < a.len {
        a[0 + 1] = a[0 + 1] + 1.0
    }
}

main {
    var data = [1.0, 2.0, 3.0]
    assert(second(data) == 2.0)
    bump_second(data)
    assert(data[0] == 1.0)
    assert(data[1] == 3.0)
    assert(data[2] == 3.0)
    assert(second(data) == 3.0)
}
