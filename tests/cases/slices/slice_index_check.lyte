// expected stdout:
// ❌ ../tests/cases/slices/slice_index_check.lyte:21:11: couldn't prove index is >= 0
//         s[-1] = 0
//               ^
// ❌ ../tests/cases/slices/slice_index_check.lyte:21:11: couldn't prove index is less than slice length
//         s[-1] = 0
//               ^
// ❌ ../tests/cases/slices/slice_index_check.lyte:15:16: couldn't prove index is less than slice length
//             dst[i] = src[i]
//                    ^

// Should get an error that i couldn't be proven to be less than dst.len
strcpy_bad(dst: [i8], src: [i8]) {
    for i in 0 .. src.len {
        dst[i] = src[i]
    }
}

// Should get an error for negative index
neg_index(s: [i32]) {
    s[-1] = 0
}

// No errors from this one.
strcpy_ok(dst: [i8], src: [i8]) {
    for i in 0 .. dst.len {
        if i < src.len {
            dst[i] = src[i]
        }
    }
}