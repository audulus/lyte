// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

main {
    var x = 1
    x = 2
    assert(x == 2)

    var y = (x = 3)
    assert(x == 3)
    assert(y == 3)

    var phase = 1.0
    phase = phase + 1.0
    assert(phase == 2.0)

    var next = (phase = phase + 1.0)
    assert(next == 3.0)
}
