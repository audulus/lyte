// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// executing LLVM code
// compilation successful
// assert(true)
// executing VM code
// assert(true)
// vm execution successful

interface Compare<A> {
    cmp(lhs: A, rhs: A) -> i32
}

sort<T, N>(array: [T; N]) -> [T; N] where Compare<T> {
    var a = array
    var i = 0
    while i < a.len {
        var j = 0
        while j < a.len - 1 - i {
            if cmp(a[j], a[j + 1]) > 0 {
                var tmp = a[j]
                a[j] = a[j + 1]
                a[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    a
}

// Implement Compare for i32
cmp(lhs: i32, rhs: i32) -> i32 { lhs - rhs }

main {
    assert(sort([3, 1, 2]) == [1, 2, 3])
}
