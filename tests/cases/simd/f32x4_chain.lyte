// f32x4 chained operations (a * b + c pattern)
// expected stdout:
// compilation successful
// 14
// 28
// 42
// 56

main {
    var a = f32x4(1.0, 2.0, 3.0, 4.0)
    var b = f32x4(2.0, 2.0, 2.0, 2.0)
    var c = f32x4(12.0, 24.0, 36.0, 48.0)
    var result = a * b + c
    print(result[0] as i32)
    print(result[1] as i32)
    print(result[2] as i32)
    print(result[3] as i32)
}
