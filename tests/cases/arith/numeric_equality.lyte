
// args: --c
// expected stdout:
// compilation successful
// 1
// 2
// 3
// 4
// 5
// 6
// 7
// 8
// 9

print(value: i32)
assert(cond: bool) → void

main {
    assert(1 == 1)
    print(1)
    assert(2 != 1)
    print(2)
    assert(1 != 2)
    print(3)
    assert(1 < 2)
    print(4)
    assert(2 > 1)
    print(5)
    assert(1 <= 1)
    print(6)
    assert(1 <= 2)
    print(7)
    assert(1 >= 1)
    print(8)
    assert(2 >= 1)
    print(9)
}
