
// args: -c
// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

main {
    var t = true
    var f = false
    assert(t)
    assert(t != f)
    assert(!f)
    assert(t || f)
    assert(t && t)
    assert(!(f || f))
    assert(!(t == f))
    assert(!f == t)
    assert(t == !f)
}
