// args: -t
// expected stdout:
// executing compiled code
// compilation successful
// assert(true)
// executing LLVM code
// compilation successful
// assert(true)
// executing VM code
// assert(true)
// vm execution successful

fact(x: i32) → i32 {

    if x == 1 {
        return 1
    }

    return x * fact(x-1)
}

main {
    assert(fact(4) == 24)
}
