// Biquad filter benchmark — bytecode golden test.
// Tracks codegen quality for the DSP hot loop.

// args: --bytecode
// expected stdout:
// fn main (params: 0, locals: 200 bytes):
//      0: SaveRegs { start_reg: 0, count: 15, slot: 80 }
//      1: LocalAddr { dst: 14, slot: 0 }
//      2: LoadF32 { dst: 1, value: 1000.0 }
//      3: LoadF32 { dst: 2, value: 44100.0 }
//      4: LoadF32 { dst: 3, value: 0.707 }
//      5: LocalAddr { dst: 4, slot: 5 }
//      6: Move { dst: 5, src: 1 }
//      7: Move { dst: 6, src: 2 }
//      8: Move { dst: 7, src: 3 }
//      9: Call { func: 1, args_start: 4, arg_count: 4 }
//     10: LocalAddr { dst: 0, slot: 5 }
//     11: LocalAddr { dst: 14, slot: 0 }
//     12: MemCopy { dst: 14, src: 0, size: 36 }
//     13: LoadImm { dst: 0, value: 10000000 }
//     14: LoadF32 { dst: 1, value: 0.0 }
//     15: LoadF32 { dst: 2, value: 440.0 }
//     16: LoadF32 { dst: 3, value: 44100.0 }
//     17: FDiv { dst: 4, a: 2, b: 3 }
//     18: LoadF32 { dst: 2, value: 2.0 }
//     19: LoadF32 { dst: 3, value: 3.1415927 }
//     20: FMul { dst: 5, a: 2, b: 3 }
//     21: Load32Off { dst: 2, base: 14, offset: 0 }
//     22: Load32Off { dst: 3, base: 14, offset: 4 }
//     23: Load32Off { dst: 6, base: 14, offset: 8 }
//     24: Load32Off { dst: 7, base: 14, offset: 12 }
//     25: Load32Off { dst: 8, base: 14, offset: 16 }
//     26: LoadImm { dst: 9, value: 0 }
// =>  27: ILtJump { a: 9, b: 0, offset: 29 }
//     28: FMul { dst: 10, a: 1, b: 5 }
//     29: SinF32 { dst: 11, src: 10 }
//     30: FAdd { dst: 1, a: 1, b: 4 }
//     31: LoadF32 { dst: 10, value: 1.0 }
//     32: FLtJump { a: 10, b: 1, offset: 2 }
//     33: LoadF32 { dst: 10, value: 1.0 }
//     34: FSub { dst: 1, a: 1, b: 10 }
// =>  35: FMul { dst: 10, a: 2, b: 11 }
//     36: LocalAddr { dst: 14, slot: 0 }
//     37: Load32Off { dst: 12, base: 14, offset: 20 }
//     38: FMul { dst: 13, a: 3, b: 12 }
//     39: FAdd { dst: 12, a: 10, b: 13 }
//     40: Load32Off { dst: 10, base: 14, offset: 24 }
//     41: FMul { dst: 13, a: 6, b: 10 }
//     42: FAdd { dst: 10, a: 12, b: 13 }
//     43: Load32Off { dst: 12, base: 14, offset: 28 }
//     44: FMul { dst: 13, a: 7, b: 12 }
//     45: FSub { dst: 12, a: 10, b: 13 }
//     46: Load32Off { dst: 10, base: 14, offset: 32 }
//     47: FMul { dst: 13, a: 8, b: 10 }
//     48: FSub { dst: 10, a: 12, b: 13 }
//     49: Load32Off { dst: 12, base: 14, offset: 20 }
//     50: Store32Off { base: 14, offset: 24, src: 12 }
//     51: Store32Off { base: 14, offset: 20, src: 11 }
//     52: Load32Off { dst: 11, base: 14, offset: 28 }
//     53: Store32Off { base: 14, offset: 32, src: 11 }
//     54: Store32Off { base: 14, offset: 28, src: 10 }
//     55: IAddImm { dst: 9, src: 9, imm: 1 }
//     56: Jump { offset: -30 }
// =>  57: LoadImm { dst: 0, value: 0 }
//     58: Move { dst: 0, src: 0 }
//     59: RestoreRegs { start_reg: 1, count: 14, slot: 88 }
//     60: Return
// fn lpf (params: 4, locals: 112 bytes):
//      0: SaveRegs { start_reg: 0, count: 8, slot: 48 }
//      1: LocalAddr { dst: 4, slot: 0 }
//      2: Store64 { addr: 4, src: 0 }
//      3: Move { dst: 0, src: 1 }
//      4: Move { dst: 1, src: 2 }
//      5: Move { dst: 2, src: 3 }
//      6: LoadF32 { dst: 3, value: 2.0 }
//      7: LoadF32 { dst: 5, value: 3.1415927 }
//      8: FMul { dst: 6, a: 3, b: 5 }
//      9: FMul { dst: 3, a: 6, b: 0 }
//     10: FDiv { dst: 0, a: 3, b: 1 }
//     11: SinF32 { dst: 1, src: 0 }
//     12: LoadF32 { dst: 3, value: 2.0 }
//     13: FMul { dst: 5, a: 3, b: 2 }
//     14: FDiv { dst: 2, a: 1, b: 5 }
//     15: CosF32 { dst: 1, src: 0 }
//     16: LoadF32 { dst: 0, value: 1.0 }
//     17: FAdd { dst: 3, a: 0, b: 2 }
//     18: LoadF32 { dst: 0, value: 1.0 }
//     19: FDiv { dst: 5, a: 0, b: 3 }
//     20: LocalAddr { dst: 0, slot: 1 }
//     21: MemZero { dst: 0, size: 36 }
//     22: LoadF32 { dst: 3, value: 1.0 }
//     23: FSub { dst: 6, a: 3, b: 1 }
//     24: FMul { dst: 3, a: 6, b: 5 }
//     25: Store32Off { base: 0, offset: 4, src: 3 }
//     26: Load32Off { dst: 3, base: 0, offset: 4 }
//     27: LoadF32 { dst: 6, value: 2.0 }
//     28: FDiv { dst: 7, a: 3, b: 6 }
//     29: Store32Off { base: 0, offset: 0, src: 7 }
//     30: Load32Off { dst: 3, base: 0, offset: 0 }
//     31: Store32Off { base: 0, offset: 8, src: 3 }
//     32: LoadF32 { dst: 3, value: 0.0 }
//     33: LoadF32 { dst: 6, value: 2.0 }
//     34: FMul { dst: 7, a: 6, b: 1 }
//     35: FSub { dst: 1, a: 3, b: 7 }
//     36: FMul { dst: 3, a: 1, b: 5 }
//     37: Store32Off { base: 0, offset: 12, src: 3 }
//     38: LoadF32 { dst: 1, value: 1.0 }
//     39: FSub { dst: 3, a: 1, b: 2 }
//     40: FMul { dst: 1, a: 3, b: 5 }
//     41: Store32Off { base: 0, offset: 16, src: 1 }
//     42: LoadF32 { dst: 1, value: 0.0 }
//     43: Store32Off { base: 0, offset: 20, src: 1 }
//     44: LoadF32 { dst: 1, value: 0.0 }
//     45: Store32Off { base: 0, offset: 24, src: 1 }
//     46: LoadF32 { dst: 1, value: 0.0 }
//     47: Store32Off { base: 0, offset: 28, src: 1 }
//     48: LoadF32 { dst: 1, value: 0.0 }
//     49: Store32Off { base: 0, offset: 32, src: 1 }
//     50: Load64 { dst: 1, addr: 4 }
//     51: MemCopy { dst: 1, src: 0, size: 36 }
//     52: RestoreRegs { start_reg: 0, count: 8, slot: 48 }
//     53: Return
// locals:
//   r0	fc
//   r1	fs
//   r2	q

struct Biquad {
    b0: f32, b1: f32, b2: f32,
    a1: f32, a2: f32,
    x1: f32, x2: f32,
    y1: f32, y2: f32
}

lpf(fc: f32, fs: f32, q: f32) -> Biquad {
    var w0 = 2.0 * 3.14159265 * fc / fs
    var alpha = sin(w0) / (2.0 * q)
    var cs = cos(w0)

    var a0 = 1.0 + alpha
    var inv = 1.0 / a0

    var bq: Biquad
    bq.b1 = (1.0 - cs) * inv
    bq.b0 = bq.b1 / 2.0
    bq.b2 = bq.b0
    bq.a1 = (0.0 - 2.0 * cs) * inv
    bq.a2 = (1.0 - alpha) * inv
    bq.x1 = 0.0
    bq.x2 = 0.0
    bq.y1 = 0.0
    bq.y2 = 0.0
    return bq
}

main {
    var bq = lpf(1000.0, 44100.0, 0.707)

    var n = 10000000
    var phase = 0.0
    var freq = 440.0 / 44100.0
    var last_y = 0.0
    var two_pi = 2.0 * 3.14159265

    for i in 0 .. n {
        var x = sin(phase * two_pi)
        phase = phase + freq
        if phase > 1.0 { phase = phase - 1.0 }

        var y = bq.b0 * x + bq.b1 * bq.x1 + bq.b2 * bq.x2 - bq.a1 * bq.y1 - bq.a2 * bq.y2
        bq.x2 = bq.x1
        bq.x1 = x
        bq.y2 = bq.y1
        bq.y1 = y
        last_y = y
    }

}
