// Generic linked list using typed arenas and typed handles.
// Supports freeing individual nodes and entire lists, with
// freed nodes recycled via a per-type free list.

// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

struct ListNodeHandle<T> {
    __idx: i32
}

struct ListNode<T> {
    value: T,
    next: i32
}

var __nodes<T>: [ListNode<T>; 256]
var __node_count<T>: i32
var __free_head<T>: i32

nil<T>() -> ListNodeHandle<T> {
    var h: ListNodeHandle<T>
    h.__idx = -1
    h
}

is_nil<T>(h: ListNodeHandle<T>) -> bool {
    h.__idx < 0
}

push<T>(head: ListNodeHandle<T>, val: T) -> ListNodeHandle<T> {
    var idx = -1
    // Reuse a freed node if one is available
    if __free_head⟨T⟩ >= 0 {
        idx = __free_head⟨T⟩
        __free_head⟨T⟩ = __nodes⟨T⟩[idx].next
    } else {
        idx = __node_count⟨T⟩
        if idx >= 0 && idx < 256 {
            __node_count⟨T⟩ = __node_count⟨T⟩ + 1
        }
    }
    if idx >= 0 && idx < 256 {
        __nodes⟨T⟩[idx].value = val
        __nodes⟨T⟩[idx].next = head.__idx
    }
    var h: ListNodeHandle<T>
    h.__idx = idx
    h
}

value<T>(h: ListNodeHandle<T>) -> T {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        return __nodes⟨T⟩[idx].value
    }
    return __nodes⟨T⟩[0].value
}

next<T>(h: ListNodeHandle<T>) -> ListNodeHandle<T> {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        var result: ListNodeHandle<T>
        result.__idx = __nodes⟨T⟩[idx].next
        return result
    }
    return nil⟨T⟩()
}

len<T>(head: ListNodeHandle<T>) -> i32 {
    var n = 0
    var cur = head
    while !is_nil(cur) {
        n = n + 1
        cur = next(cur)
    }
    n
}

// Free a single node, returning it to the free list.
// Returns the next node in the list.
free_node<T>(h: ListNodeHandle<T>) -> ListNodeHandle<T> {
    let idx = h.__idx
    var nxt = nil⟨T⟩()
    if idx >= 0 && idx < 256 {
        nxt.__idx = __nodes⟨T⟩[idx].next
        __nodes⟨T⟩[idx].next = __free_head⟨T⟩
        __free_head⟨T⟩ = idx
    }
    nxt
}

// Free an entire list, returning all nodes to the free list.
free_list<T>(head: ListNodeHandle<T>) {
    var cur = head
    while !is_nil(cur) {
        cur = free_node(cur)
    }
}

main {
    __node_count⟨i32⟩ = 0
    __free_head⟨i32⟩ = -1

    var head = nil()

    // T=i32 inferred from the value argument (10, 20, 30)
    head = push(head, 10)
    head = push(head, 20)
    head = push(head, 30)

    // T inferred from head: ListNodeHandle<i32>
    assert(len(head) == 3)
    assert(value(head) == 30)

    let second = next(head)
    assert(value(second) == 20)

    let third = next(second)
    assert(value(third) == 10)

    assert(is_nil(next(third)))

    // Free the entire list and verify it's empty
    free_list(head)
    // node_count stays at 3, but all 3 nodes are on the free list

    // Build a new list — should reuse freed nodes (no new allocation)
    var head2 = nil()
    head2 = push(head2, 100)
    head2 = push(head2, 200)
    // node_count should still be 3 since nodes were reused
    assert(__node_count⟨i32⟩ == 3)
    assert(len(head2) == 2)
    assert(value(head2) == 200)
    assert(value(next(head2)) == 100)

    // Push one more — still reusing
    head2 = push(head2, 300)
    assert(__node_count⟨i32⟩ == 3)

    // Push a fourth — this one allocates fresh
    head2 = push(head2, 400)
    assert(__node_count⟨i32⟩ == 4)

    // f32 list — separate storage, separate handle type
    __node_count⟨f32⟩ = 0
    __free_head⟨f32⟩ = -1
    var fhead = nil()
    fhead = push(fhead, 3.14)
    fhead = push(fhead, 2.71)
    assert(value(fhead) > 2.0)
    assert(len(fhead) == 2)
}
