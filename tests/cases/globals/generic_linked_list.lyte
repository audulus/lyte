// Generic linked list using typed arenas and typed handles.

// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

// Typed handle — prevents confusing a ListNodeHandle<i32> with a
// ListNodeHandle<f32> or an unrelated i32.
struct ListNodeHandle<T> {
    __idx: i32
}

struct ListNode<T> {
    value: T,
    next: i32
}

var __nodes<T>: [ListNode<T>; 256]
var __node_count<T>: i32

nil_handle<T>() -> ListNodeHandle<T> {
    var h: ListNodeHandle<T>
    h.__idx = 0 - 1
    h
}

is_nil<T>(h: ListNodeHandle<T>) -> i32 {
    if h.__idx < 0 { return 1 }
    return 0
}

push<T>(head: ListNodeHandle<T>, val: T) -> ListNodeHandle<T> {
    let idx = __node_count⟨T⟩
    if idx >= 0 && idx < 256 {
        __nodes⟨T⟩[idx].value = val
        __nodes⟨T⟩[idx].next = head.__idx
        __node_count⟨T⟩ = __node_count⟨T⟩ + 1
    }
    var h: ListNodeHandle<T>
    h.__idx = idx
    h
}

list_value<T>(h: ListNodeHandle<T>) -> T {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        return __nodes⟨T⟩[idx].value
    }
    return __nodes⟨T⟩[0].value
}

list_next<T>(h: ListNodeHandle<T>) -> ListNodeHandle<T> {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        var result: ListNodeHandle<T>
        result.__idx = __nodes⟨T⟩[idx].next
        return result
    }
    return nil_handle⟨T⟩()
}

list_len<T>(head: ListNodeHandle<T>) -> i32 {
    var n = 0
    var cur = head
    while is_nil⟨T⟩(cur) == 0 {
        n = n + 1
        cur = list_next⟨T⟩(cur)
    }
    n
}

main {
    __node_count⟨i32⟩ = 0

    // Build list: 30 -> 20 -> 10 -> nil
    var head = nil_handle⟨i32⟩()
    head = push⟨i32⟩(head, 10)
    head = push⟨i32⟩(head, 20)
    head = push⟨i32⟩(head, 30)

    assert(list_len⟨i32⟩(head) == 3)
    assert(list_value⟨i32⟩(head) == 30)

    let second = list_next⟨i32⟩(head)
    assert(list_value⟨i32⟩(second) == 20)

    let third = list_next⟨i32⟩(second)
    assert(list_value⟨i32⟩(third) == 10)

    assert(is_nil⟨i32⟩(list_next⟨i32⟩(third)) == 1)

    // Also works with f32 — separate storage, separate handle type
    __node_count⟨f32⟩ = 0
    var fhead = nil_handle⟨f32⟩()
    fhead = push⟨f32⟩(fhead, 3.14)
    fhead = push⟨f32⟩(fhead, 2.71)
    assert(list_value⟨f32⟩(fhead) > 2.0)
    assert(list_len⟨f32⟩(fhead) == 2)

    // Type safety: this would be a type error if uncommented:
    // let bad = list_value⟨i32⟩(fhead)  // fhead is ListNodeHandle<f32>, not <i32>
}
