// Generic linked list using typed arenas and typed handles.
// T is inferred from ListNodeHandle<T> arguments — only nil_handle
// needs an explicit type arg since it has no value to infer from.

// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

struct ListNodeHandle<T> {
    __idx: i32
}

struct ListNode<T> {
    value: T,
    next: i32
}

var __nodes<T>: [ListNode<T>; 256]
var __node_count<T>: i32

nil_handle<T>() -> ListNodeHandle<T> {
    var h: ListNodeHandle<T>
    h.__idx = 0 - 1
    h
}

is_nil<T>(h: ListNodeHandle<T>) -> i32 {
    if h.__idx < 0 { return 1 }
    return 0
}

push<T>(head: ListNodeHandle<T>, val: T) -> ListNodeHandle<T> {
    let idx = __node_count⟨T⟩
    if idx >= 0 && idx < 256 {
        __nodes⟨T⟩[idx].value = val
        __nodes⟨T⟩[idx].next = head.__idx
        __node_count⟨T⟩ = __node_count⟨T⟩ + 1
    }
    var h: ListNodeHandle<T>
    h.__idx = idx
    h
}

list_value<T>(h: ListNodeHandle<T>) -> T {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        return __nodes⟨T⟩[idx].value
    }
    return __nodes⟨T⟩[0].value
}

list_next<T>(h: ListNodeHandle<T>) -> ListNodeHandle<T> {
    let idx = h.__idx
    if idx >= 0 && idx < 256 {
        var result: ListNodeHandle<T>
        result.__idx = __nodes⟨T⟩[idx].next
        return result
    }
    return nil_handle⟨T⟩()
}

list_len<T>(head: ListNodeHandle<T>) -> i32 {
    var n = 0
    var cur = head
    while is_nil(cur) == 0 {
        n = n + 1
        cur = list_next(cur)
    }
    n
}

main {
    __node_count⟨i32⟩ = 0

    // Only nil_handle needs ⟨i32⟩ — no value to infer T from
    var head = nil_handle⟨i32⟩()

    // T=i32 inferred from the value argument (10, 20, 30)
    head = push(head, 10)
    head = push(head, 20)
    head = push(head, 30)

    // T inferred from head: ListNodeHandle<i32>
    assert(list_len(head) == 3)
    assert(list_value(head) == 30)

    let second = list_next(head)
    assert(list_value(second) == 20)

    let third = list_next(second)
    assert(list_value(third) == 10)

    assert(is_nil(list_next(third)) == 1)

    // f32 list — separate storage, separate handle type
    __node_count⟨f32⟩ = 0
    var fhead = nil_handle⟨f32⟩()
    fhead = push(fhead, 3.14)
    fhead = push(fhead, 2.71)
    assert(list_value(fhead) > 2.0)
    assert(list_len(fhead) == 2)
}
