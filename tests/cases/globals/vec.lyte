// Vec<T> built on a global memory pool, similar to Rust's Vec.
// Uses a bump allocator with reallocation (copy to new region) on grow.
// Each Vec<T> is a handle: (start, len, cap) into __pool<T>.

// expected stdout:
// compilation successful
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)
// assert(true)

struct Vec<T> {
    __start: i32,
    __len: i32,
    __cap: i32
}

// Global typed memory pool (bump allocator)
var __pool<T>: [T; 4096]
var __pool_top<T>: i32

// Allocate a contiguous region of `size` slots, return start index.
__alloc<T>(size: i32) -> i32 {
    let start = __pool_top⟨T⟩
    if start + size <= 4096 {
        __pool_top⟨T⟩ = start + size
    }
    start
}

// Create an empty Vec with a given initial capacity.
new_vec_cap<T>(cap: i32) -> Vec<T> {
    var v: Vec<T>
    v.__start = __alloc⟨T⟩(cap)
    v.__len = 0
    v.__cap = cap
    v
}

// Create an empty Vec with default capacity 4.
new_vec<T>() -> Vec<T> {
    new_vec_cap⟨T⟩(4)
}

// Return the number of elements.
vec_len<T>(v: Vec<T>) -> i32 {
    v.__len
}

// Return the current capacity.
vec_cap<T>(v: Vec<T>) -> i32 {
    v.__cap
}

// Get element at index.
vec_get<T>(v: Vec<T>, idx: i32) -> T {
    let i = v.__start + idx
    if i >= 0 && i < 4096 {
        return __pool⟨T⟩[i]
    }
    return __pool⟨T⟩[0]
}

// Set element at index (mutates pool directly).
vec_set<T>(v: Vec<T>, idx: i32, val: T) {
    let i = v.__start + idx
    if i >= 0 && i < 4096 {
        __pool⟨T⟩[i] = val
    }
}

// Grow: allocate new region with double capacity, copy old data.
// Returns the new Vec handle (old region is leaked — bump allocator).
__grow<T>(v: Vec<T>) -> Vec<T> {
    let new_cap = v.__cap * 2
    let new_start = __alloc⟨T⟩(new_cap)
    // Copy old elements to new region
    for i in 0 .. v.__len {
        let src = v.__start + i
        let dst = new_start + i
        if src >= 0 && src < 4096 && dst >= 0 && dst < 4096 {
            __pool⟨T⟩[dst] = __pool⟨T⟩[src]
        }
    }
    var nv: Vec<T>
    nv.__start = new_start
    nv.__len = v.__len
    nv.__cap = new_cap
    nv
}

// Push an element. Returns updated Vec (may reallocate).
vec_push<T>(v: Vec<T>, val: T) -> Vec<T> {
    var w = v
    if w.__len >= w.__cap {
        w = __grow(w)
    }
    let i = w.__start + w.__len
    if i >= 0 && i < 4096 {
        __pool⟨T⟩[i] = val
    }
    w.__len = w.__len + 1
    w
}

// Pop the last element. Returns updated Vec.
vec_pop<T>(v: Vec<T>) -> Vec<T> {
    var w = v
    if w.__len > 0 {
        w.__len = w.__len - 1
    }
    w
}

// Return the last element.
vec_last<T>(v: Vec<T>) -> T {
    vec_get(v, v.__len - 1)
}

// Check if empty.
vec_empty<T>(v: Vec<T>) -> bool {
    v.__len == 0
}

main {
    __pool_top⟨i32⟩ = 0

    // Basic push/get
    var v = new_vec⟨i32⟩()
    v = vec_push(v, 10)
    v = vec_push(v, 20)
    v = vec_push(v, 30)
    assert(vec_len(v) == 3)
    assert(vec_get(v, 0) == 10)
    assert(vec_get(v, 1) == 20)
    assert(vec_get(v, 2) == 30)

    // Set
    vec_set(v, 1, 99)
    assert(vec_get(v, 1) == 99)

    // Push past initial capacity (4) to trigger grow
    v = vec_push(v, 40)
    assert(vec_len(v) == 4)
    assert(vec_cap(v) == 4)  // exactly at capacity, no grow yet

    v = vec_push(v, 50)       // this triggers grow to cap 8
    assert(vec_len(v) == 5)
    assert(vec_cap(v) == 8)
    assert(vec_get(v, 4) == 50)

    // Old data survived the grow
    assert(vec_get(v, 0) == 10)
    assert(vec_get(v, 2) == 30)
    assert(vec_get(v, 3) == 40)

    // Pop
    v = vec_pop(v)
    assert(vec_len(v) == 4)
    assert(vec_last(v) == 40)

    // Empty check
    assert(!vec_empty(v))

    // Independent f32 vec (separate pool)
    __pool_top⟨f32⟩ = 0
    var fv = new_vec⟨f32⟩()
    fv = vec_push(fv, 3.14)
    fv = vec_push(fv, 2.71)
    assert(vec_len(fv) == 2)
    assert(vec_get(fv, 0) > 3.0)
}
